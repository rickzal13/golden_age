# Production Dockerfile — Golden Age Web (PWA)
# Build: docker build -f docker/Dockerfile.web -t golden-age-web .
# Run:   docker run -p 8080:80 golden-age-web

# Stage 1: Build the React app
FROM oven/bun:1.3-slim AS builder

WORKDIR /app

COPY package.json bun.lock tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY apps/web/package.json apps/web/

RUN bun install

COPY packages/shared/ packages/shared/
COPY apps/web/ apps/web/

ENV VITE_API_URL=/api
RUN bun run --cwd apps/web vite build

# Stage 2: Serve with Nginx
FROM nginx:1.27-alpine

RUN addgroup --system app && adduser --system --ingroup app app

# Create writable log directory for app user
RUN mkdir -p /var/log/nginx && touch /var/log/nginx/access.log /var/log/nginx/error.log && \
    chown -R app:app /var/log/nginx /var/cache/nginx /tmp

COPY docker/nginx/nginx.conf /etc/nginx/nginx.conf
COPY docker/nginx/conf.d/ /etc/nginx/conf.d/

COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

RUN chown -R app:app /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget -qO- http://localhost:80/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
