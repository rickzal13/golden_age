# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/golden_age

# Redis
REDIS_URL=redis://localhost:6379

# S3-Compatible Storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=golden-age-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# JWT (generate with: openssl genpkey -algorithm RSA -out private.pem && openssl rsa -pubout -in private.pem -out public.pem)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase Cloud Messaging
FCM_SERVICE_ACCOUNT_JSON=

# Email (AWS SES / Mailpit for local)
SES_FROM_ADDRESS=noreply@goldenage.app
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# App URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
